# Copy this to .env and fill in your values. NEVER commit .env.

# REQUIRED (live mode only, min 32 chars)
JWT_SECRET=your-256-bit-secret-generate-with-openssl-rand-base64-32

# OPTIONAL (mock mode if absent)
GROQ_API_KEY=gsk_xxxxxxxxxxxx
GOOGLE_AI_API_KEY=AIzaxxxxxxxxxxxx
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxx

# AUTHENTICATION
AUTH_REQUIRED=true

# DEPLOYMENT
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:8000

# RATE LIMITING
MAX_CONNECTIONS_PER_IP=5
MAX_CONNECTIONS_PER_USER=3
MAX_MESSAGES_PER_MINUTE=60

# AUDIO LIMITS
MAX_AUDIO_SIZE_BYTES=960000
MAX_AUDIO_BUFFER_BYTES=480000

# TTS VOICE SETTINGS
# edge-tts voice (free, no key needed). run `edge-tts --list-voices` to see all options.
TTS_VOICE=en-US-AriaNeural
# gemini tts voice (requires GOOGLE_AI_API_KEY). common options: Kore, Enceladus, Puck, Charon.
GEMINI_TTS_VOICE=Kore

# FILE TOOL LIMITS
MAX_FILE_SIZE_BYTES=102400
MAX_FILES_PER_SESSION=20
MAX_TOTAL_BYTES_PER_SESSION=1048576
MAX_FILE_PATH_DEPTH=5

# AUDIT LOG SECURITY
# defaults to JWT_SECRET if not set
# AUDIT_LOG_KEY=separate-key-for-audit-signing
